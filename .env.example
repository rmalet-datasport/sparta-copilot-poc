# Sparta Co-Pilot — Variables d'environnement requises
# Copier ce fichier en .env.local et renseigner les valeurs

# Clé API Anthropic — obtenir sur console.anthropic.com
ANTHROPIC_API_KEY=

# Mot de passe de la démo — partagé avec les participants
DEMO_PASSWORD=

# Secret de signature du cookie de session — chaîne aléatoire d'au moins 32 caractères
DEMO_COOKIE_SECRET=
